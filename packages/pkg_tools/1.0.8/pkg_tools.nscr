	<file name="<procpath>/tools/gui/keyValBrowser.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $keyValBrowser()
		* ============================================================================================
		* Hinzugefügt: 2021-05-02, um 14:05:33 *#
		
		##! \procedure keyValBrowser
		##! Displays the passed key-value list in an external window in a human-readable from. Elements
		##! may not be modified in this browser.
		##!
		##! \param _keyValList{}  Key-value list to display
		##! \param _sCustomTitle  (!!=""!!) An optional custom window title
		##! \return VAL  The window ID of the created browser window
		procedure $keyValBrowser(_keyValList{}, _sCustomTitle = "")
			##~ Füge hier deine Kommandos und Ausdrücke ein.
			var nWinId
			cst tabularKeyValList{}
			
			## Transform the key-value list into tabular form
			## (i.e. separate ky-value by tabulators)
			tabularKeyValList{} = _keyValList{{1:2:nlen}} + "\t" + to_string(_keyValList{{2:2:nlen}});
			
			## Create the browser window
			nWinId = window "<this>/keyval";
			
			## Add the key-value list in tabular form and 
			## return
			window nWinId -set value=tabularKeyValList{} item=0;
			
			## If the user supplied a custom title, set that here
			if (_sCustomTitle.len)
				window nWinId -set label=_sCustomTitle;
			endif
			
			return nWinId;
		endprocedure
		
		##~ Ergänze hier weitere lokale Prozeduren
		
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/gui/openGridLocator.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $openGridLocator()
		* ============================================================================================
		* Hinzugefügt: 2021-05-04, um 22:23:58 *#
		
		##! \procedure openGridLocator
		##! Opens up a grid locator window, references the passed global tables
		##! and displays the passed map in the embedded grapher object.
		##!
		##! \param _map()&  Data grid containing a 2D map
		##! \param _pointsStorage()&  A global table to store the located points in
		##! \param _nLocatedPoints  (!!=1!!) The number of points, which the user shall select
		##! \return VAL  The ID of the opened window
		procedure $openGridLocator(_map()&, _pointsStorage()&, _nLocatedPoints = 1) :: explicit mask
			var nWinId
			
			## Create the window
			nWinId = window "<this>/gridLocator";
			
			## Update the internal properties
			window nWinId -set value=to_string(_map()) prop="sMapName";
			window nWinId -set value=to_string(_pointsStorage()) prop="sStorage";
			window nWinId -set value=_nLocatedPoints prop="nPoints";
			
			## Display the passed map in the grapher
			dens _map() -set aspect=1 box streamto={nWinId, 0} reset
			
			return nWinId;
		endprocedure
		
		##~ Ergänze hier weitere lokale Prozeduren
		
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/gui/openGridPainter.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $openGridPainter()
		* ============================================================================================
		* Hinzugefügt: 2021-05-03, um 09:58:36 *#
		
		##! \procedure openGridPainter
		##! Opens up a Map Painter window and plots the passed map into it. The map is referenced via 
		##! its name in the Map Painter window and will be overwritten by any paint action.
		##!
		##! \param _map()&  Map to display and reference
		##! \return VAL  The window ID of the created Map Painter Window
		procedure $openGridPainter(_map()&) :: explicit mask
			var nWinId
			
			## Open window layout
			nWinId = window "<this>/gridPainter";
			
			## Plot the map to the grapher object
			dens _map() -set streamto={nWinId, 0} aspect=1 box reset
			
			## Store the map name in the internal properties
			window nWinId -set value=to_string(_map()) prop="sMapName";
			
			return nWinId;
		endprocedure
		
		##~ Ergänze hier weitere lokale Prozeduren
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/gui/progress.nlyt">
		##! \layout Progress
		##!
		##! Defines a graphical progress bar as an alternative
		##! to the usual !!progress!! command.
		layout -title="Progress" size={450,80} ##{400,50} for only 1 gauge
			statictext "Current Progress:" -set id=0
			gauge -set id=1
			gauge -set id=2 state=hidden
		endlayout
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/gui/progressBar.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $progressBar()
		* ============================================================================================
		* Hinzugefügt: 2021-05-01, um 20:03:46 *#
		
		##! \procedure progressBar
		##! This procedure provides a graphical progress visualisation with one or two progress bars, a 
		##! status text and a title, both of them are customizeable. The progress visualisation is controlled
		##! via a key-value list containing only optional parameters. This key-value list can be used to 
		##! set the value of one or both progress bars, to show or hide the latter one and to customize the
		##! title as well as the status message text.
		##!
		##! \param _nWinId  (!!=-1!!) Window id of an existing window or !!-1!!, if a new window shall be created
		##! \param _barState{}  (!!={"bar", 0}!!) Key-value list containing information about the displayed
		##! window. The key-value list accepts the following keys (including their default values): 
		##! !!"bar" = 0, "bar2" = -1, "title" = "Progress", "message" = "Current Progress", "close" = false!!.
		##! Both !!"bar"!! and !!"bar2"!! define the values of the two progress bars, where a value of !!-1!! for
		##! the second !!"bar2"!! will hide it.
		##! \return VAL  Returns either the ID of the current window or the success state, when a window 
		##! shall be closed
		procedure $progressBar(_nWinId = -1, _barState{} = {"bar", 0}) :: explicit mask
			## Create local vars
			var nBar1Val = 0, nBar2Val = -1, bClose
			str sTitle = "Progress", sMessage = "Current Progress"
			
			## Shall we create a new window?
			if (_nWinId == -1)
				_nWinId = window "<this>/progress";
			endif
			
			## Get the settings for the progress bar
			## using the user-supplied keyval list
			{nBar1Val, nBar2Val, sTitle, sMessage, bClose} = getkeyval(_barState{:}, {"bar", "bar2", "title", "message", "close"}, {0, -1, "Progress", "Current Progress", 0});
			
			## Shall we close the window?
			if (bClose)
				return window _nWinId -close;
			endif
			
			## Update the window correspondingly
			window _nWinId -set label=sTitle;
			window _nWinId -set value=sMessage item=0;
			
			## Set the value of the first progress bar
			window _nWinId -set value=nBar1Val item=1;
			
			## Enable or disable the second progress bar
			## and update its value
			if (nBar2Val != -1)
				window _nWinId -set state=enabled item=2;
				window _nWinId -set value=nBar2Val item=2;
			else
				window _nWinId -set state=hidden item=2;
			endif
			
			## Return the window id
			return _nWinId;
		endprocedure
		
		##~ Ergänze hier weitere lokale Prozeduren
		
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/strings/camelize.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $camelize()
		* ============================================================================================
		* Hinzugefügt: 2021-05-01, um 22:33:45 *#
		
		##! \procedure camelize
		##! This procedure converts the passed string into CamelCase using either whitespaces or
		##! underscores as word separators.
		##!
		##! \param _sString  The string to convert to CamelCase
		##! \return STR  The CamelCase string
		procedure $camelize(_sString) :: explicit mask
			## Create a string variable to get a tokenized list of strings
			str sTokens
			
			## Convert to lowercase first, replace whitespace with underscores and tokenize the whole 
			## string into separate strings
			_sString = replaceall(to_lowercase(_sString), " ", "_");
			sTokens = _sString.splt("_");
			
			## Convert every first character to an uppercase character
			sTokens = to_uppercase(sTokens.at(1)) + sTokens.sub(2);
			
			## Return a joined version of the tokenized strings
			return strjoin(sTokens);
		endprocedure
		
		##~ Ergänze hier weitere lokale Prozeduren
		
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/strings/replaceAllFromList.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $replaceAllFromList()
		* ============================================================================================
		* Hinzugefügt: 2021-05-07, um 21:24:02 *#
		
		##! \procedure replaceAllFromList
		##! Uses the passed key-value list to replace every occurence of the keys with
		##! their corresponding values from the key-value list.
		##! \remark This procedure is intended for arbitrary long lists and is not reasonable for cases,
		##! where two or three chained calls to !!replaceall()!! would result in the same behavior.
		##!
		##! \param _stringsToReplace{}  Strings, where the occurences shall be replaced
		##! \param _keyValToReplace{}  Key-value list, whose key occurences shall be replaced
		##! \return {STR}  The strings after all occurences where replaced
		procedure $replaceAllFromList(_stringsToReplace{}, _keyValToReplace{}) :: explicit mask
			## Replace every key occurence in the string
			## with its corresponding value
			for ({sKey, val} -> _keyValToReplace{})
				_stringsToReplace{} = replaceall(_stringsToReplace{}, sKey, valtostr(val));
			endfor
			
			## Return the replaced string
			return _stringsToReplace{};
		endprocedure
		
		##~ Ergänze hier weitere lokale Prozeduren
		
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/strings/reverse.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $reverse()
		* ============================================================================================
		* Hinzugefügt: 2018-12-02, um 12:15:47 *#
		
		##! \procedure reverse
		##! Reverts the order of the characters in the passed string.
		##!
		##! \param _sStr  (!!=""!!) String to revert
		##! \return STR  The reverted string
		procedure $reverse(_sStr = "") :: explicit mask
			
			if (!_sStr.len)
				return "";
			endif
			
			return sum(_sStr.at({_sStr.len:1}));
		endprocedure
		
		#**Ende der Prozedur
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://sites.google.com/site/numereframework/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/strings/strip.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $strip()
		* ============================================================================================
		* Hinzugefügt: 2021-05-03, um 11:26:39 *#
		
		##! \procedure strip
		##! Strips all surrounding occurences of the selected characters from the passed string. The
		##! characters are only stripped, if they are leading or trailing (no internal characters are
		##! removed).
		##!
		##! \param _sString  (!!=""!!) String to strip
		##! \param _sChars  (!!=" \t"!!) Characters to be stripped from the string
		##! \return STR  The stripped string
		procedure $strip(_sString = "", _sChars = " \t") :: explicit
			_sString = _sString.sub(_sString.nmtch(_sChars));
			_sString = _sString.sub(1, _sString.nrmtch(_sChars));
			return _sString;
		endprocedure
		
		##~ Ergänze hier weitere lokale Prozeduren
		
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/strings/wrapWords.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $wrapWords()
		* ============================================================================================
		* Hinzugefügt: 2018-12-09, um 10:08:47 *#
		
		##! \procedure wrapWords
		##! This procedure provides word wrapping for the passed string at the desired length.
		##!
		##! \param _sStringToWrap  The string to be word wrapped
		##! \param _nLength  (!!=0!!) The length of the new lines. Uses the terminal width,
		##! if the length is zero.
		##! \return STR  The wrapped string
		procedure $wrapWords(_sStringToWrap, _nLength = 0) :: explicit mask
			var nLastLineBreak = 1
			
			## If the entered length is zero or smaller then use the current terminal's window size for the 
			## line length
			if (_nLength < 1)
				{_nLength, 0} = get -windowsize -asval;
			endif
			
			## Find the points to wrap the lines
			for (i = 1:_sStringToWrap.len)
				## Is this already a line break?
				if (_sStringToWrap.at(i) == "\n")
					nLastLineBreak = i;
				endif
				
				## Are we now longer than the line length?
				if (i - nLastLineBreak >= _nLength)
					## Find the last whitespace from here
					nLastLineBreak = _sStringToWrap.rfnd(" ", i);
					
					## Replace the whitespace with a linebreak character
					_sStringToWrap = replace(_sStringToWrap, nLastLineBreak, 1, "\n");
				endif
			endfor -mask
			
			return _sStringToWrap;
		endprocedure
		
		#**Ende der Prozedur
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://sites.google.com/site/numereframework/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/structures/intersectKeyVals.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $intersectKeyVals()
		* ============================================================================================
		* Hinzugefügt: 2021-05-05, um 22:41:37 *#
		
		##! \procedure intersectKeyVals
		##! Calculates the intersection of the two passed key-value lists, where the values from the
		##! second list are used to fill the intersected list
		##!
		##! \param _keyValToIntersect{}  Key-value list to intersect the keys with
		##! \param _keyValToInsert{}  Key-value list to use the values from
		##! \return CST  The intersected key-value list
		procedure $intersectKeyVals(_keyValToIntersect{}, _keyValToInsert{}) :: explicit mask
			var nLocation
			cst intersected{}
			
			## Go through the second list
			for ({sKey, val} -> _keyValToIntersect{})
				## Try to locate the entries of the second list in the first one
				nLocation = locate(_keyValToInsert{{1:2:nlen}}, sKey, 0);
				
				## If a match is found, append the entries of the second list to the intersected list
				if (nLocation)
					intersected{nlen+1:} = _keyValToInsert{2*nLocation-1:2*nLocation};
				endif
			endfor
			
			## Return the intersected key-value list
			return intersected{};
		endprocedure
		
		##~ Ergänze hier weitere lokale Prozeduren
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/structures/makeKeyVals.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $makeKeyVals()
		* ============================================================================================
		* Hinzugefügt: 2021-05-02, um 16:22:31 *#
		
		##! \procedure makeKeyVals
		##! Composes a key-value list from the two clusters !!_keys{}!! and !!_values{}!! and returns it.
		##!
		##! \param _keys{}  A cluster containing the keys of the key-value list
		##! \param _values{}  A cluster containing the values of the key-value list
		##! \return CST  The composed key-value list
		procedure $makeKeyVals(_keys{}, _values{})
			cst keyVal{}
			var nLength
			
			## Ensure that both clusters have the same
			## number of elements
			if (cnt(_keys{}) != cnt(_values{}))
				throw "makeKeyVals :: The number of elements in keys{} does not match to the number of values{}."
			endif
			
			## Get the elements
			nLength = cnt(_keys{});
			
			## Compose the final key-value list
			keyVal{{1:2:2*nLength}} = _keys{};
			keyVal{{2:2:2*nLength}} = _values{};
			
			return keyVal{};
		endprocedure
		
		##~ Ergänze hier weitere lokale Prozeduren
		
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/structures/mergeKeyVals.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $mergeKeyVals()
		* ============================================================================================
		* Hinzugefügt: 2021-05-05, um 22:03:45 *#
		
		##! \procedure mergeKeyVals
		##! Merges two key-value lists into a single one, where identical keys from the first key-value list
		##! are overwritten by the values of the second list. Missing values are simply appended.
		##!
		##! \param _keyValToUpdate{}  Key-value list to be updated with the entries of the second list
		##! \param _keyValToInsert{}  Key-value list, whose entries are inserted into the first list
		##! \return CST  The combined key-value list
		procedure $mergeKeyVals(_keyValToUpdate{}, _keyValToInsert{}) :: explicit mask
			var nLocation
			
			## Go through the second list
			for ({sKey, val} -> _keyValToInsert{})
				## Try to locate the entries of the second list in the first one
				nLocation = locate(_keyValToUpdate{{1:2:nlen}}, sKey, 0);
				
				## If no match is found, append the entries, otherwise simply 
				## overwrite them
				if (!nLocation)
					_keyValToUpdate{nlen+1:} = {sKey, val};
				else
					_keyValToUpdate{2*nLocation} = val;
				endif
				
				i++;
			endfor
			
			## Return the updated key-value list
			return _keyValToUpdate{};
		endprocedure
		
		##~ Ergänze hier weitere lokale Prozeduren
		
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/structures/sortKeyVals.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $sortKeyVals()
		* ============================================================================================
		* Hinzugefügt: 2021-05-05, um 22:51:05 *#
		
		##! \procedure sortKeyVals
		##! Sorts the keys of the passed key-value list ascending ignoring case and returns the 
		##! sorted list.
		##!
		##! \param _keyVals{}  Key value list to be sorted
		##! \return CST  The sorted key-value list
		procedure $sortKeyVals(_keyVals{})
			cst keys{} = _keyVals{{1:2:nlen}}, idx{}
			
			## Sort the keys ascending ignoring case and return the
			## sorting index
			idx{} = 2 * sort keys{} -set index ignorecase;
			
			## Copy keys and values in the new order
			_keyVals{{1:2:nlen}} = _keyVals{idx{}-1};
			_keyVals{{2:2:nlen}} = _keyVals{idx{}};
			
			## Return the sorted list
			return _keyVals{};
		endprocedure
		
		##~ Ergänze hier weitere lokale Prozeduren
		
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/tests.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $tests()
		* ============================================================================================
		* Hinzugefügt: 2021-05-18, um 21:35:37 *#
		
		##! \procedure tests
		##! This procedure runs all tests for the tools.
		procedure $tests()
			namespace thisfile
			
			$extractTableParams();
			$getColFromTable();
			$getLineFromTable();
			$getFoldersRecursively();
			$getNextArgument();
			$stripSpaces();
			$getLatestVersion();
			
			$this~grids~tests();
			$this~strings~tests();
			$this~structures~tests();
			
			return void;
		endprocedure
		
		
		##! \procedure extractTableParams
		##! Test the extract table params functionality.
		procedure $extractTableParams() :: explicit test
			print "tools: Extract table params test ..."
			tab testtab()
			str sTabName
			testtab(:, 1) = {1:10};
			testtab(:, 2) = sin({1:10});
			sTabName = testtab().name;
			sTabName = sTabName.sub(1, sTabName.fnd("(")-1);
			
			assert $this~extractTableParams(testtab().name) == {sTabName, 1, 10, 1, 2};
			
			return void;
		endprocedure
		
		
		##! \procedure getColFromTable
		##! Test the column read functionality.
		procedure $getColFromTable() :: explicit test
			print "tools: Get col from table test ..."
			tab testtab(), res()
			testtab(:, 1) = {1:10};
			testtab(:, 2) = sin({1:10});
			assert $this~getColFromTable(testtab().name) == {1:10};
			return void;
		endprocedure
		
		
		##! \procedure getLineFromTable
		##! Test the line read functionality.
		procedure $getLineFromTable() :: explicit test
			print "tools: Get line from table test ..."
			tab testtab()
			testtab(1, :) = {1:10};
			testtab(2, :) = sin({1:10});
			assert $this~getLineFromTable(testtab().name) == {1:10};
			return void;
		endprocedure
		
		
		##! \procedure getFoldersRecursively
		##! Test the recursive folder functionality.
		procedure $getFoldersRecursively() :: explicit test
			print "tools: Get folders recursively test ..."
			assert $this~getFoldersRecursively("<this>") == ("<this>" + {"", "/grids", "/gui", "/strings", "/structures"});
			return void;
		endprocedure
		
		
		##! \procedure getNextArgument
		##! Test the get next argument functionality.
		procedure $getNextArgument() :: explicit test
			print "tools: Get next argument test ..."
			assert $this~getNextArgument("cos(norm(x,y)), sin(x), tan(x)") == {"cos(norm(x,y))", " sin(x), tan(x)"};
			return void;
		endprocedure
		
		
		##! \procedure stripSpaces
		##! Test the strip spaces functionality.
		procedure $stripSpaces() :: explicit test
			print "tools: Strip spaces test ..."
			assert $this~stripSpaces("  Hello world!   ") == "Hello world!";
			return void;
		endprocedure
		
		
		##! \procedure getLatestVersion
		##! Test the latest version reading functionality.
		procedure $getLatestVersion() :: explicit test
			print "tools: Get latest version test ..."
			warn "Test disabled due to problems with SourceForge"
			## 	str sLatestVersion = $this~getLatestVersion();
			## 	assert sLatestVersion.fnd("numere-win-v") && sLatestVersion.fnd(".exe");
			return void;
		endprocedure
		
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/strings/tests.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $tests()
		* ============================================================================================
		* Hinzugefügt: 2021-05-18, um 17:37:31 *#
		
		##! \procedure tests
		##! This procedure runs all tests for the strings tools.
		procedure $tests() :: explicit mask
			namespace thisfile
			
			$camelize();
			$replaceAllFromList();
			$reverse();
			$strip();
			$wrapWords();
			$createColumns();
			$format();
			$toRomanNumbers();
			$fromRomanNumbers();
			
			return void;
		endprocedure
		
		
		##! \procedure camelize
		##! Test the camelize functionality.
		procedure $camelize() :: explicit test
			print "tools~strings: Camelize test ..."
			assert $this~camelize("Some string with white spaces") == "SomeStringWithWhiteSpaces";
			assert $this~camelize(" Another string with_mixtures and suffixes_") == "AnotherStringWithMixturesAndSuffixes";
			assert $this~camelize("THIS_IS_AN_ALL_UPPERCASE") == "ThisIsAnAllUppercase";
			return void;
		endprocedure
		
		
		##! \procedure replaceAllFromList
		##! Test the replace all from a key-value list functionality.
		procedure $replaceAllFromList() :: explicit test
			print "tools~strings: Replace all from list test ..."
			assert $this~replaceAllFromList("Lorem ipsum dolor sit amet, consetetur sadipscing elitr, sed diam nonumy eirmod tempor invidunt ut labore et dolore magna aliquyam", {"lo", "**", "magna", "-----"}) == "Lorem ipsum do**r sit amet, consetetur sadipscing elitr, sed diam nonumy eirmod tempor invidunt ut labore et do**re ----- aliquyam";
			return void;
		endprocedure
		
		
		##! \procedure reverse
		##! Test the character reversion functionality.
		procedure $reverse() :: explicit test
			print "tools~strings: Reverse test ..."
			assert $this~reverse("Hello world!") == "!dlrow olleH";
			return void;
		endprocedure
		
		
		##! \procedure strip
		##! Test the surrounding character stripping functionality.
		procedure $strip() :: explicit test
			print "tools~strings: Strip test ..."
			assert $this~strip("  Hello world!    ") == "Hello world!";
			assert $this~strip("***Hello world!   ", "*") == "Hello world!   ";
			return void;
		endprocedure
		
		
		##! \procedure wrapWords
		##! Test the word wrapping functionality.
		procedure $wrapWords() :: explicit test
			print "tools~strings: Wrap words test ..."
			assert $this~wrapWords("Lorem ipsum dolor sit amet, consetetur sadipscing elitr, sed diam nonumy eirmod tempor invidunt ut labore et dolore magna aliquyam", 30) == "Lorem ipsum dolor sit amet,\nconsetetur sadipscing elitr,\nsed diam nonumy eirmod tempor\ninvidunt ut labore et dolore\nmagna aliquyam";
			assert $this~wrapWords("Lorem ipsum dolor sit amet,\nconsetetur sadipscing elitr, sed diam nonumy eirmod tempor invidunt ut labore et dolore magna aliquyam", 30) == "Lorem ipsum dolor sit amet,\nconsetetur sadipscing elitr,\nsed diam nonumy eirmod tempor\ninvidunt ut labore et dolore\nmagna aliquyam";
			return void;
		endprocedure
		
		
		##! \procedure createColumns
		##! Test the column creating functionality.
		procedure $createColumns() :: explicit test
			print "tools~strings: Create columns test ..."
			str sText = "Several characteristics define a data set's structure and properties. These include the number and types of the attributes or variables, and various statistical measures applicable to them, such as standard deviation and kurtosis.[4]\n\nThe values may be numbers, such as real numbers or integers, for example representing a person's height in centimeters, but may also be nominal data (i.e., not consisting of numerical values), for example representing a person's ethnicity."
			
			assert $this~createColumns(sText, 2, 100) == "Several characteristics define a data set's    The values may be numbers, such as real    \nstructure and properties. These include the    numbers or integers, for example           \nnumber and types of the attributes or          representing a person's height in          \nvariables, and various statistical measures    centimeters, but may also be nominal data  \napplicable to them, such as standard           (i.e., not consisting of numerical values),\ndeviation and kurtosis.[4]                     for example representing a person's        \n                                               ethnicity.                                 ";
			assert $this~createColumns(sText, 2, 60, 10) == "Several                     The values may be \ncharacteristics             numbers, such as  \ndefine a data               real numbers or   \nset's structure             integers, for     \nand properties.             example           \nThese include the           representing a    \nnumber and types            person's height in\nof the attributes           centimeters, but  \nor variables, and           may also be       \nvarious                     nominal data      \nstatistical                 (i.e., not        \nmeasures                    consisting of     \napplicable to               numerical values),\nthem, such as               for example       \nstandard deviation          representing a    \nand kurtosis.[4]            person's          \n                            ethnicity.        ";
			assert $this~createColumns(sText, 4, 180,  10) == "Several characteristics define a          various statistical measures              The values may be numbers, such           consisting of numerical values),\ndata set's structure and                  applicable to them, such as               as real numbers or integers, for          for example representing a      \nproperties. These include the             standard deviation and                    example representing a person's           person's ethnicity.             \nnumber and types of the                   kurtosis.[4]                              height in centimeters, but may  \nattributes or variables, and                                                        also be nominal data (i.e., not ";
			
			return void;
		endprocedure
		
		
		##! \procedure format
		##! Test the string formatting functionality.
		procedure $format() :: explicit test
			print "tools~strings: String formatting test ..."
			assert $this~format("{1}, {2}!", {"Hello", "World"}) == "Hello, World!";
			assert $this~format("{1}, {2}, {3} ... {4}!", {1,2,1+2,"vorbei"}) == "1, 2, 3 ... vorbei!";
			assert $this~format("{1}, {2}, {3} ... {4}!") == "{1}, {2}, {3} ... {4}!";
			assert $this~format("{1}, {2}, {3} ... {4}!", {"","",""}) == ", ,  ... {4}!";
			return void;
		endprocedure
		
		
		##! \procedure toRomanNumbers
		##! Test the roman numbers conversion functionality.
		procedure $toRomanNumbers() :: explicit test
			print "tools~strings: Roman number conversion test ..."
			assert $this~toRomanNumbers(2022) == "MMXXII";
			assert $this~toRomanNumbers(1987) == "MCMLXXXVII";
			assert $this~toRomanNumbers(123) == "CXXIII";
			assert $this~toRomanNumbers(555) == "DLV";
			return void;
		endprocedure
		
		
		##! \procedure fromRomanNumbers
		##! Test the inverse roman numbers conversion functionality.
		procedure $fromRomanNumbers() :: explicit test
			print "tools~strings: Inverse roman number conversion test ..."
			assert $this~fromRomanNumbers("MMXXII") == 2022;
			assert $this~fromRomanNumbers("mcmlxxxvii") == 1987;
			assert $this~fromRomanNumbers("cxxiii") == 123;
			assert $this~fromRomanNumbers("DLV") == 555;
			return void;
		endprocedure
		
		
		
		
		#**Ende der Datei
