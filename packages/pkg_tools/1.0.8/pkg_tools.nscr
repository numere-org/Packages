		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/structures/tests.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $tests()
		* ============================================================================================
		* Hinzugefügt: 2021-05-18, um 20:05:49 *#
		
		##! \procedure tests
		##! This procedure runs all tests for the structures tools.
		procedure $tests() :: explicit mask
			namespace thisfile
			
			$makeKeyVals();
			$mergeKeyVals();
			$intersectKeyVals();
			$sortKeyVals();
			$printKeyVals();
			
			return void;
		endprocedure
		
		
		##! \procedure makeKeyVals
		##! Test the key-value list generation functionality.
		procedure $makeKeyVals() :: explicit test
			print "tools~structures: Make Key-Value test ..."
			assert $this~makeKeyVals({"key1", "key2", "key3"}, {"a", true, #<loadpath>}) == {"key1", "a", "key2", true, "key3", #<loadpath>};
			assert $this~makeKeyVals({"key1", "key2", "key3"}, {1:3}) == {"key1", 1, "key2", 2, "key3", 3};
			return void;
		endprocedure
		
		
		##! \procedure mergeKeyVals
		##! Test the merging of two key-value lists.
		procedure $mergeKeyVals() :: explicit test
			print "tools~structures: Merge Key-Value test ..."
			assert $this~mergeKeyVals({"key1", "a", "key2", false}, {"key2", true, "key3", #<loadpath>}) == {"key1", "a", "key2", true, "key3", #<loadpath>};
			assert $this~mergeKeyVals({"key1", "a", "Key2", false}, {"key3", #<loadpath>, "Key2", true}) == {"key1", "a", "Key2", 1, "key3", #<loadpath>};
			return void; 
		endprocedure
		
		
		##! \procedure intersectKeyVals
		##! Test the intersection of two key-value lists.
		procedure $intersectKeyVals() :: explicit test
			print "tools~structures: Intersect Key-Value test ..."
			assert $this~intersectKeyVals({"key1", "a", "key2", false}, {"key2", true, "key3", #<loadpath>, "key1", "value"}) == {"key1", "value", "key2", true};
			return void;
		endprocedure
		
		
		##! \procedure sortKeyVals
		##! Test the sorting of a key-value list.
		procedure $sortKeyVals() :: explicit test
			print "tools~structures: Sort Key-Value test ..."
			assert $this~sortKeyVals({"key2", true, "Key3", #<loadpath>, "key1", "value"}) == {"key1", "value", "key2", true, "Key3", #<loadpath>};
			return void;
		endprocedure
		
		
		##! \procedure printKeyVals
		##! Test the possibility to print a key-value list to a string.
		procedure $printKeyVals() :: explicit test
			print "tools~structures: Print Key-Value test ..."
			str sLP = #<loadpath>
			assert $this~printKeyVals({"key2", true, "Key3", #<loadpath>, "key1", "value"}) == "key2:    true" + repeat(" ", sLP.len-4) + "\nKey3:    " + sLP + "\nkey1:    value" + repeat(" ", sLP.len-5);
			return void;
		endprocedure
		
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/grids/deserialize.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $deserialize()
		* ============================================================================================
		* Hinzugefügt: 2021-05-20, um 11:31:50 *#
		
		##! \procedure deserialize
		##! De-serialize a x-y-z coordinate set into a regular x-y grid, where every point in the grid
		##! matches to exactly one z value in the coordinate set.
		##!
		##! \param _xyzpoints()  Serialized coordinate set
		##! \param _grid()&  Output data grid
		##! \param _xyz{}  (!!={1,2,3}!!) Column indices of x,y, and z in the serialized coordinate set
		##! \return VAL  Size of x axis in the final grid
		##! \return VAL  Size of y axis in the final grid
		procedure $deserialize(_xyzpoints(), _grid()&, _xyz{} = {1,2,3}) :: explicit mask
			tab coords()
			var nCoordsX, nCoordsY
			
			## Ensure that the column types as "value-like" types
			if (or(_xyzpoints().typeof(_xyz{}) == "string"))
				throw "deserialize :: One or more columns of the passed table cannot be interpreted as numerical values."
			endif
			
			## Get the coordinate list and make it unique
			matop coords() = unique(_xyzpoints(:, _xyz{1:2}), 2);
			
			## Create the target data grid
			{nCoordsX, nCoordsY} = coords().num.cols;
			datagrid 0 -set x=coords(:, 1) y=coords(:, 2) target=_grid()
			
			## Convert the "cartesian" coordinates to grid coordintates
			matop coords() = coordstogrid(coords(), _xyzpoints(:, _xyz{1:2}));
			
			## Assemble the deserialized matrix
			matop _grid(:,3:) = assemble(coords(:, 1), coords(:, 2), _xyzpoints(:, _xyz{3}));
			return {nCoordsX, nCoordsY};
		endprocedure
		
		##~ Ergänze hier weitere lokale Prozeduren
		
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/grids/isGrid.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $isGrid()
		* ============================================================================================
		* Hinzugefügt: 2021-05-21, um 21:58:42 *#
		
		##! \procedure isGrid
		##! Returns, whether the passed table has the correct dimensions to fulfill the requirements of
		##! a grid. This does not mean that it automatically has to be a grid as there's no programmatical
		##! easy way to determine this property.
		##!
		##! \param _table()  The table to examine
		##! \return LOG  True, if the table fulfills the requirements, false otherwise
		procedure $isGrid(_table()) :: explicit mask
			var nAxisX, nAxisY, nSizeX, nSizeY
			
			## Check minimal dimension requirements
			if (num(_table(1, :)) < 3)
				return false;
			endif
			
			## Get axis and z matrix sizes
			{nAxisX, nAxisY} = _table().num.cols.every({1,2});
			matop {nSizeX, nSizeY} = size(_table(:, 3:));
			
			## Check the sizes
			if (nSizeX < nAxisX || nSizeY < nAxisY)
				return false;
			endif
			
			return true;
		endprocedure
		
		##~ Ergänze hier weitere lokale Prozeduren
		
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/grids/serialize.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $serialize()
		* ============================================================================================
		* Hinzugefügt: 2021-05-20, um 11:31:40 *#
		
		##! \procedure serialize
		##! Serialize a datagrid into x-y-z coordinate pairs, where each grid point occurs once in the 
		##! serialized table with dimx * dimy points times three columns.
		##!
		##! \param _grid()  Input data grid
		##! \param _xyzpoints()&  Output serialized grid
		##! \return VAL  The number of rows in the serialized grid
		procedure $serialize(_grid(), _xyzpoints()&) :: explicit mask
			var nCoordsX, nCoordsY
			nCoordsX = num(_grid(:, 1));
			nCoordsY = num(_grid(:, 2));
			
			matop _xyzpoints(:, 1) = reshape(repmat(_grid(1:nCoordsX, 1), 1, nCoordsY), nCoordsX*nCoordsY, 1);
			matop _xyzpoints(:, 2) = repmat(_grid(1:nCoordsY, 2), nCoordsX, 1);
			matop _xyzpoints(:, 3) = reshape(_grid(1:nCoordsX, 3:nCoordsY+2), nCoordsX * nCoordsY, 1);
			
			return nCoordsX * nCoordsY;
		endprocedure
		
		##~ Ergänze hier weitere lokale Prozeduren
		
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/grids/tests.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $tests()
		* ============================================================================================
		* Hinzugefügt: 2021-05-20, um 11:31:58 *#
		
		##! \procedure tests
		##! This procedure runs all tests for the grids tools.
		procedure $tests() :: explicit mask
			namespace thisfile
			tab testdata(), ret(), ret2()
			datagrid sin(x) + cos(y) -set [-2:2, -4:4] samples=40 target=testdata()
			
			$serialize(testdata(), ret());
			$deserialize(ret(), ret2());
			$roundTrip(testdata(), ret2());
			$isGrid();
			$extractSubGrid();
			
			return void;
		endprocedure
		
		
		##! \procedure serialize
		##! Test the serializing functionality.
		##!
		##! \param _testdata()  Datagrid to serialize
		##! \param _serialized()&  Serialized datagrid
		procedure $serialize(_testdata(), _serialized()&) :: explicit test
			print "tools~grids: Serialize test ..."
			assert $this~serialize(_testdata(), _serialized());
			assert num(_serialized(:, 1)) == num(_testdata(:, 1)) * num(_testdata(:, 2));
			return void;
		endprocedure
		
		
		##! \procedure deserialize
		##! Test the de-serializing functionality.
		##!
		##! \param _testdata()  Serialized datagrid
		##! \param _grid()  De-serialized datagrid
		procedure $deserialize(_testdata(), _grid()&) :: explicit test
			print "tools~grids: De-serialize test ..."
			assert $this~deserialize(_testdata(), _grid()) == {40, 40};
			assert num(_testdata(:, 1)) == num(_grid(:, 1)) * num(_grid(:, 2));
			return void;
		endprocedure
		
		
		##! \procedure roundTrip
		##! Perform a roundtrip check.
		##!
		##! \param _origData()  Original data grid
		##! \param _processedData()  Twice transformed grid
		procedure $roundTrip(_origData(), _processedData()) :: explicit test
			print "tools~grids: Round trip test ..."
			assert matop _origData() == _processedData();
		endprocedure
		
		
		##! \procedure isGrid
		##! Test the grid determination functionality.
		procedure $isGrid() :: explicit test
			print "tools~grids: Is grid test ..."
			tab grid(), falsegrid()
			datagrid sinc(norm(x,y)) -set [-5:5,-5:5] target=grid()
			falsegrid(:, 1) = {1:20};
			falsegrid(:, 2) = {1:15};
			falsegrid(:, 3) = {1:10};
			falsegrid(:, 3) = {1:18};
			
			assert $this~isGrid(grid());
			assert !$this~isGrid(falsegrid());
			return void;
		endprocedure
		
		
		##! \procedure extractSubGrid
		##! Test the grid extraction functionality.
		procedure $extractSubGrid() :: explicit test
			print "tools~grids: Extract subgrid test ..."
			tab grid(), extracted()
			datagrid abs(x) <= 2 && abs(y) <= 2 ? 2 : 0 -set [-5:5,-5:5] target=grid()
			extracted() = $this~extractSubGrid(grid(), {-2,2}, {-2,2});
			assert extracted().min.grid == extracted().max.grid;
			assert extracted().min.grid == 2;
			assert extracted().sum.grid == grid().sum.grid;
			return void;
		endprocedure
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/strings/format.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $format()
		* ============================================================================================
		* Hinzugefügt: 2022-02-28, um 21:30:22 *#
		
		##! \procedure format
		##! Uses the passed formatting string (where each token is indicated with !!{N}!!, where !!N!!
		##! is the token number) to insert the passed tokens at the desired positions. The formatted
		##! string is returned afterwards.
		##!
		##! \param _sFormatString  The formatting string
		##! \param _tokens{}  (!!={""}!!) The token list
		##! \return STR  The formatted string
		procedure $format(_sFormatString, _tokens{} = {}) :: mask explicit
			var nTokenCount = cnt(_tokens{})
			
			## If no token was passed, simply return the formatting string
			if (!nTokenCount)
				return _sFormatString;
			endif
			
			## Make a key-value list from the tokens
			_tokens{{2:2:2*nTokenCount}} = #(_tokens{});
			_tokens{{1:2:2*nTokenCount}} = "{" + #{1:nTokenCount} + "}";
			
			## Replace the tokens using the key-value list
			return $this~replaceAllFromList(_sFormatString, _tokens{});
		endprocedure
		
		##~ Ergänze hier weitere lokale Prozeduren
		
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
	<endfile>

	<file name="<procpath>/tools/grids/extractSubGrid.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $extractSubGrid()
		* ============================================================================================
		* Hinzugefügt: 2022-03-23, um 14:56:36 *#
		
		##! \procedure extractSubGrid
		##! Extracts a part of the grid, which can be selected from the axis ranges. The target ranges can
		##! be passed as parameters.
		##!
		##! \param _grid()  The source data grid
		##! \param _xRange{}  (!!={-inf,inf}!!) The target x range of the new data grid
		##! \param _yRange{}  (!!={-inf,inf}!!) The target y range of the new data grid
		##! \return TAB  The new data grid
		procedure $extractSubGrid(_grid(), _xRange{} = {-inf,inf}, _yRange{} = {-inf,inf}) :: explicit mask
			tab subGrid()
			cst colIdx{}, rowIdx{}
			
			## Get the indices for rows and columns
			matop rowIdx{} = logtoidx(_grid(:,1) >= min(_xRange{}) && _grid(:,1) <= max(_xRange{}));
			matop colIdx{} = logtoidx(_grid(:,2) >= min(_yRange{}) && _grid(:,2) <= max(_yRange{}));
			
			## Ensure that the indices have a valid value
			if (!and(rowIdx{}) || !and(colIdx{}))
				throw "extractSubGrid :: One of the ranges is either too small or out of the grid bounds."
			endif
			
			## Fill up the axes
			subGrid(:, 1) = _grid(rowIdx{}, 1);
			subGrid(:, 2) = _grid(colIdx{}, 2);
			
			## Fill up the data interval
			matop subGrid(:, 3:) = _grid(rowIdx{}, colIdx{}+2);
			return subGrid();
		endprocedure
		
		##~ Ergänze hier weitere lokale Prozeduren
		
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
	<endfile>

	<file name="<procpath>/tools/strings/fromRomanNumbers.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $fromRomanNumbers()
		* ============================================================================================
		* Hinzugefügt: 2022-03-29, um 21:37:54 *#
		
		##! \procedure fromRomanNumbers
		##! Converts a string of roman number literals to actual integers.
		##!
		##! \param _sValue  The roman number literal string
		##! \return VAL  The corresponding integer
		procedure $fromRomanNumbers(_sValue) :: explicit mask
			var nValue = 0
			_sValue = to_uppercase(_sValue);
			
			if (_sValue.nmtch("MDCLXVI"))
				throw "fromRomanNumbers :: The passed string \"" + _sValue + "\" contains characters, which are not valid roman number literals."
			endif
			
			for (i = 1:_sValue.len)
				if (_sValue.at(i) == "M")
					nValue += 1000;
				elseif (_sValue.sub(i, 2) == "CM")
					nValue += 900;
					i++;
				elseif (_sValue.sub(i, 2) == "CD")
					nValue += 400;
					i++;
				elseif (_sValue.at(i) == "C")
					nValue += 100;
				elseif (_sValue.at(i) == "D")
					nValue += 500;
				elseif (_sValue.sub(i, 2) == "XC")
					nValue += 90;
					i++;
				elseif (_sValue.sub(i, 2) == "XL")
					nValue += 40;
					i++;
				elseif (_sValue.at(i) == "X")
					nValue += 10;
				elseif (_sValue.at(i) == "L")
					nValue += 50;
				elseif (_sValue.sub(i, 2) == "IX")
					nValue += 9;
					i++;
				elseif (_sValue.sub(i, 2) == "IV")
					nValue += 4;
					i++;
				elseif (_sValue.at(i) == "I")
					nValue += 1;
				elseif (_sValue.at(i) == "V")
					nValue += 5;
				endif
			endfor
			
			return nValue;
		endprocedure
		
		##~ Ergänze hier weitere lokale Prozeduren
		
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
	<endfile>

	<file name="<procpath>/tools/strings/toRomanNumbers.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $toRomanNumbers()
		* ============================================================================================
		* Hinzugefügt: 2022-03-29, um 21:01:51 *#
		
		##! \procedure toRomanNumbers
		##! Converts a value in the range from 1 to 3999 to roman number literals and returns them as a
		##! string.
		##!
		##! \param _nValue  The value to convert
		##! \return STR  The roman number literal string
		procedure $toRomanNumbers(_nValue) :: explicit mask
			str sRomanNumber
			var nCurrVal
			
			## Convert to integer
			_nValue = rint(_nValue);
			
			## Check if number is in valid range
			if (_nValue < 1 || _nValue > 3999)
				throw "toRomanNumbers :: Only integral values from 1 to 3999 are representable as roman numbers."
			endif
			
			## Format thousands
			if (_nValue >= 1'k)
				sRomanNumber = repeat("M", floor(_nValue / 1'k));
				_nValue = _nValue % 1'k;
			endif
			
			## Format hundreds
			if (_nValue >= 100)
				nCurrVal = floor(_nValue / 100);
				_nValue = _nValue % 100;
				sRomanNumber += $thisfile~formatTenths(nCurrVal, "C", "D", "M");
			endif
			
			## Format tenths
			if (_nValue >= 10)
				nCurrVal = floor(_nValue / 10);
				_nValue = _nValue % 10;
				sRomanNumber += $thisfile~formatTenths(nCurrVal, "X", "L", "C");
			endif
			
			## Format ones
			sRomanNumber += $thisfile~formatTenths(_nValue, "I", "V", "X");
			return sRomanNumber;
		endprocedure
		
		
		##! \procedure formatTenths
		##! Helper procedure to format the current tenths.
		##!
		##! \param _nValue  The current multiple
		##! \param _sSingle  The single value character
		##! \param _sFive  The "five" character
		##! \param _sTen  The "ten" character
		##! \return STR  The formatted string
		procedure $formatTenths(_nValue, _sSingle, _sFive, _sTen) :: explicit
			if (_nValue == 9)
				return _sSingle + _sTen;
			elseif (_nValue >= 5)
				return _sFive + repeat(_sSingle, _nValue-5);
			elseif (_nValue == 4)
				return _sSingle + _sFive;
			else
				return repeat(_sSingle, _nValue);
			endif
		endprocedure
		
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
	<endfile>

	<file name="<procpath>/tools/structures/printKeyVals.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $printKeyVals()
		* ============================================================================================
		* Hinzugefügt: 2022-05-01, um 14:36:04 *#
		
		##! \procedure printKeyVals
		##! Converts a key-value list into a printable string.
		##!
		##! \param _keyVals{}  The key-value list to print
		##! \return STR  The print-ready formatted string
		procedure $printKeyVals(_keyVals{}) :: explicit inline
			## Convert the key-value list into a formatted string
			return strjoin(justify(_keyVals{{1:2:nlen}} + ":") + "    " \\
			+ justify(#_keyVals{{2:2:nlen}}), "\n");
		endprocedure
		
		##~ Ergänze hier weitere lokale Prozeduren
		
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
	<endfile>

	<file name="<procpath>/tools/getLatestVersion.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $getLatestVersion()
		* ============================================================================================
		* Hinzugefügt: 2022-04-30, um 21:27:48 *#
		
		##! \procedure getLatestVersion
		##! Gets the file name of the latest installer on SourceForge. Shall indicate, whether an update
		##! might be reasonable.
		##! \return STR  The installer file name
		procedure $getLatestVersion()
			##~ Füge hier deine Kommandos und Ausdrücke ein.
			str sPage, sTitle
			
			## Get the page contents
			sPage = url "https://sourceforge.net/projects/numere/files/"
			
			## Find the download link
			var nPos = sPage.fnd("/projects/numere/files/latest/download");
			
			## Find the title of the download link - will contain the file name
			nPos = sPage.fnd("title=", nPos);
			
			## Extract the title
			sTitle = getopt(sPage, nPos+6);
			
			## Get the installer file name
			sTitle = textparse(sTitle, "\"/%a/%s:%a");
			
			## Return the installer file name
			return sTitle;
		endprocedure
		
		##~ Ergänze hier weitere lokale Prozeduren
		
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
	<endfile>

	<file name="<procpath>/tools/strings/createColumns.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $createColumns()
		* ============================================================================================
		* Hinzugefügt: 2022-07-05, um 21:31:26 *#
		
		##! \procedure createColumns
		##! Transforms the passed text into a multi column layout. The number of columns and the size of the
		##! separating whitespace may be changed. The text is automatically (more-or-less) evenly
		##! distributed along the selected number of columns.
		##!
		##! \param _sText  Text to layout
		##! \param _nColCount  (!!=1!!) Number of columns
		##! \param _nTotalLength  (!!=0!!) Total available horizontal space in characters. Uses the terminal
		##! width, if the length is zero or smaller than the number of columns.
		##! \param _nSeparatorCharCount  (!!=4!!) The length of the separating whitespace between the columns
		##! \return STR  The ready-to-print layouted text
		procedure $createColumns(_sText, _nColCount = 1, _nTotalLength = 0, _nSeparatorCharCount = 4) :: explicit mask
			var nCharsPerColumn, nLinesPerColumn, nTotalLines
			cst textLines{}, renderedColumns{}
			
			## If the entered length is smaller than the number of columns then use the current terminal's
			## window size for the line length
			if (_nTotalLength < _nColCount)
				{_nTotalLength, 0} = get -windowsize -asval;
			endif
			
			nCharsPerColumn = floor(_nTotalLength / _nColCount) - _nSeparatorCharCount - 1;
			
			## Ensure that there are characters per column
			if (nCharsPerColumn <= 0)
				throw "createColumns :: The selected column layout is impossible with this line length.";
			endif
			
			## Use wrapWords to convert the text into a single column layout, which can then be broken down
			## to multiple columns afterwards
			_sText = $this~wrapWords(_sText, nCharsPerColumn);
			
			## Prepare the alignment
			textLines{} = justify(_sText.splt("\n", true));
			nTotalLines = cnt(textLines{});
			nLinesPerColumn = roof(num(textLines{}) / _nColCount);
			
			## For a single column, we are already finished
			if (_nColCount <= 1)
				_sText = strjoin(textLines{}, "\n", true);
			else
				## Add the first column
				renderedColumns{} = textLines{1:nLinesPerColumn};
				
				## Append all remaining columns
				for (i = 2:_nColCount)
					renderedColumns{} += repeat(" ", _nSeparatorCharCount) + textLines{(i-1)*nLinesPerColumn+1 : min(i*nLinesPerColumn, nTotalLines)};
				endfor	
				
				## Combine all single lines to a single string
				_sText = strjoin(renderedColumns{}, "\n", true);
			endif
			
			return _sText;
		endprocedure
		
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
	<endfile>

	return;
<endinstall>

warn "Dies ist ein Installations-Script. Um die enthaltenen Prozeduren zu installieren, muss es mit 'install \"<this>/pkg_tools\"' ausgeführt werden."


