		-author="Erik Hänel"
		-version="1.0.8"
		-type=TYPE_PACKAGE
		-license="Apache-2.0"
		-desc="This package provides basic procedures via the \"tools\" namespace, which will enhance and simplify the workflow in many cases. This package also provides multiple sub-namespaces containing functionalities for special cases."
		-keywords="Tools,Utils,Helpers,GUI,Strings,Structures,Grids"
		-changelog="2025-03-28 v1.0.8:\n  c Changed code to cope with new v1.1.7.2504\n  + Modernized some solutions to speed up calculation\n2023-01-17 v1.0.7:\n  + Added missing procedure $tools~getLatestVersion()\n  + Added missing procedure $tools~strings~createColumns()\n2022-12-30 v1.0.6:\n  + Added keywords\n  + Added changeslog"
		-flags=DISABLE_SCREEN_OUTPUT
		-requireversion="1.1.7.2412"
	<endinfo>

	<file name="<procpath>/tools/extractTableParams.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $extractTableParams()
		* ============================================================================================
		* HinzugefÃ¼gt: 2021-05-01, um 15:32:07 *#
		
		##! \procedure extractTableParams
		##! This procedure returns the name of the passed table access string !!sTable!!
		##! and the corresponding table indices as !!{sName,i1,i2,j1,j2}!!. The possible
		##! values of the second parameter !!nType!! may be looked up in the description
		##! of the function !!getindices()!!.
		##!
		##! \param _sTable  (!!=""!!) A table access string like !!table(i,j)!!
		##! \param _nType  (!!=0!!) The interpretation type used to detect the missing indices. Same meaning as the second parameter in !!getindices()!!
		##! \return STR  The name of the table
		##! \return VAL  First row index
		##! \return VAL  Last row index
		##! \return VAL  First column index
		##! \return VAL  Last column index
		procedure $extractTableParams(_sTable = "", _nType = 0) :: explicit
			var i1, i2, j1, j2
			if (!is_data(_sTable) || !_sTable.len)
				throw "Kein Datensatz angegeben."
			endif
			{i1, i2, j1, j2} = getindices(_sTable, _nType);
			_sTable =  _sTable.sub(1, _sTable.fnd("(")-1);
			_sTable = $tools~strings~strip(_sTable);
			return {_sTable, i1, i2, j1, j2};
		endprocedure
		
		#**Ende der Datei
		* NumeRe: Framework fÃ¼r Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/getColFromTable.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $getColFromTable()
		* ============================================================================================
		* Hinzugefügt: 2021-05-01, um 15:32:07 *#
		
		##! \procedure getColFromTable
		##! Returns the contents of the selected column !!_nCol!!
		##! from the table !!_sTable!!, where !!_nLine0!! defines
		##! the first and !!_nLine1!! the last row indices to be
		##! extracted.
		##! \remark This procedure is deprecated. Please use !!TAB().aliasof()!! instead.
		##!
		##! \param _sTable  (!!=""!!) Table access string like !!table(i,j)!! with or without the parentheses
		##! \param _nCol  (!!=1!!) Selected column to be extracted
		##! \param _nLine0  (!!=1!!) First row index to be extracted
		##! \param _nLine1  (!!=inf!!) Last row index to be extracted
		##! \return {VAL}  The contents of the selected column
		procedure $getColFromTable(_sTable = "", _nCol = 1, _nLine0 = 1, _nLine1 = inf) :: explicit
			warn "The procedure $tools~getColFromTable() is deprecated. Please use the TAB().aliasof() method instead."
			tab localtab()
			localtab().aliasof(_sTable);
			return localtab(_nLine0:_nLine1, _nCol); 
		endprocedure
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/getFoldersRecursively.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $getFoldersRecursively()
		* ============================================================================================
		* Hinzugefügt: 2021-05-01, um 15:32:07 *#
		
		##! \procedure getFoldersRecursively
		##! This procedure will find all folders below the passed base path folder
		##! until the specified level of recursion.
		##!
		##! \param _sBasePath  (!!=""!!) Base path to start the recursion from
		##! \param _nLevel  (!!=2!!) Maximal number of recursions
		##! \return {STR}  The detected unique folders
		procedure $getFoldersRecursively(_sBasePath = "", _nLevel = 2) :: mask
			if (!_sBasePath.len)
				throw "The base path is empty."
			endif
			
			str sCurrentDir
			cst folders{}
			folders{} = _sBasePath;
			
			if (_nLevel)
				for (i = 1:_nLevel)
					_sBasePath += "/*";
					sCurrentDir = getfolderlist(_sBasePath, true);
					
					if (num(sCurrentDir))
						folders{nlen+1:} = sCurrentDir;
					endif
				endfor -mask
			endif
			
			folders{} = folders{logtoidx(!endswith(folders{}, "/..") && !endswith(folders{}, "/."))};
			sort folders{}
			
			return folders{};
		endprocedure
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/getLineFromTable.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $getLineFromTable()
		* ============================================================================================
		* Hinzugefügt: 2021-05-01, um 15:32:07 *#
		
		##! \procedure getLineFromTable
		##! Returns the contents of the selected line !!_nLine!!
		##! from the table !!_sTable!!, where !!_nCol0!! defines
		##! the first and !!_nCol1!! the last column indices to be
		##! extracted.
		##! \remark This procedure is deprecated. Please use !!TAB().aliasof()!! instead.
		##!
		##! \param _sTable  (!!=""!!) Table access string like !!table(i,j)!! with or without the parentheses
		##! \param _nLine  (!!=1!!) Selected row to be extracted
		##! \param _nCol0  (!!=1!!) First column index to be extracted
		##! \param _ncol1  (!!=inf!!) Last column index to be extracted
		##! \return {VAL}  The contents of the selected row
		procedure $getLineFromTable(_sTable = "", _nLine = 1, _nCol0 = 1, _nCol1 = inf) :: explicit
			warn "The procedure $tools~getLineFromTable() is deprecated. Please use the TAB().aliasof() method instead."
			tab localtab()
			localtab().aliasof(_sTable);
			return localtab(_nLine, _nCol0:_nCol1);
		endprocedure
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/getNextArgument.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $getNextArgument()
		* ============================================================================================
		* Hinzugefügt: 2021-05-01, um 15:32:07 *#
		
		##! \procedure getNextArgument
		##! This procedure extracts the next argument from the passed argument list
		##! !!sArgList!!. Per call to this procedure the current first element of
		##! the list is extracted and returned as !!{sElement, sArgList}!! with
		##! !!sArgList!! being shortened by the extracted element.
		##!
		##! \param _sArgList  (!!=""!!) Argument list to extract the next argument from
		##! \return STR  The next argument
		##! \return STR  The remaining part of the list
		procedure $getNextArgument(_sArgList = "") :: explicit
			str sArgument
			
			## Return an empty string, if an empty string was passed
			if (!_sArgList.len)
				return {"", ""};
			endif
			
			## Try to find the end of the current argument
			for (i = 1:_sArgList.len)
				if (_sArgList.at(i) == ",")
					## This is a argument separator
					sArgument = _sArgList.sub(1, i-1), _sArgList = _sArgList.sub(i+1);
					break
				elseif (or(_sArgList.at(i) == {"(", "[", "{"}))
					## Jump over parentheses
					i += getmatchingparens(_sArgList.sub(i)) - 1;
				endif
			endfor -mask
			
			## If we did not find any comma, we only have a single argument
			if (!sArgument.len && _sArgList.len)
				return {_sArgList, sArgument};
			endif
			
			return {sArgument, _sArgList};
		endprocedure
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/stripSpaces.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $stripSpaces()
		* ============================================================================================
		* Hinzugefügt: 2021-05-01, um 15:32:07 *#
		
		##! \procedure stripSpaces
		##! This procedure removes leading and trailing whitespaces and tabulator
		##! characters from the passed string !!sString!!.
		##! \remark This procedure is deprecated. Please use !!$tools~strings~strip()!! instead.
		##!
		##! \param _sString  (!!=""!!) String to strip whitespaces from
		##! \return STR  The stripped string
		procedure $stripSpaces(_sString = "") :: explicit
			warn "The procedure $tools~stripSpaces() is deprecated. Please use $tools~strings~strip() instead."
			return $tools~strings~strip(_sString);
		endprocedure
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/gui/gridLocator.nlyt">
		#**********************************************************************************************
		* WINDOW-LAYOUT: gridLocator 
		* ============================================================================================
		* Hinzugefügt: 2021-05-04, um 21:58:56 *#
		
		##! \layout gridLocator
		##! Creates a simple grapher window with an onclick event handler aggregating located points 
		##! in the displayed map
		layout -title="NumeRe: Grid Locator" size={800,800}
			grapher -set id=0 size={750,750} onclick=$this~gridLocatorEvent()
			prop sMapName = "", sStorage = "", nPoints = 0
		endlayout
		
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/gui/gridLocatorEvent.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $gridLocatorEvent()
		* ============================================================================================
		* Hinzugefügt: 2021-05-04, um 22:00:39 *#
		
		##! \procedure gridLocatorEvent
		##! Event handler procedure for the gridLocator window layout. Gets called, when the user
		##! clicks on a location in the displayed grapher object. Gets the coordinates, transforms
		##! them to the closest grid coordinates and adds marks at the corresponding positions.
		##!
		##! \param _nWinId  The window Id of the current gridLocator window
		##! \param _nItemId  The item Id of the grapher object
		##! \param _event{}  Additional event information as key-val list
		procedure $gridLocatorEvent(_nWinId, _nItemId, _event{}) :: event
			str sName = "", sLocationsStorage = ""
			var nLocatedPoints = 0
			tab localMap(), localLocations(), points()
			cst coords{}, size{}
			
			sName = window _nWinId -get value prop= "sMapName";
			sLocationsStorage = window _nWinId -get value prop= "sStorage";
			nLocatedPoints = window _nWinId -get value prop= "nPoints";
			
			localMap().aliasof(sName);
			localLocations().aliasof(sLocationsStorage);
			
			## get coords
			coords{} = getkeyval(_event{}, "value", 0, true);
			
			## Convert to grid coords
			matop coords{} = rint(coordstogrid(localMap(:, 1:2), transpose(coords{})));
			size{} = localMap().size;
			
			## Ensure that we're in the map
			if (or(coords{} < 1) || or(coords{} > size{}))
				return void;
			endif
			
			## Store the found coordinates
			localLocations(nlines+1, :) = coords{};
			
			## Get the corresponding x-y coords
			points(:, 1) = localMap(localLocations(:, 1), 1);
			points(:, 2) = localMap(localLocations(:, 2), 2);
			points(:, 3) = points(:, 1) * 0 + localMap().avg.grid;
			
			## Re-Plot the data grid with the found points
			compose 
				dens localMap() -set noalpha box aspect=1 streamto={_nWinId, 0} rotate=0,0
				plot3d points() "Located points [" + #num(localLocations(:, 1)) + "/" + #nLocatedPoints + "]" -set connect
			endcompose
			
			## Close the window after enough locations had been performed
			if (num(localLocations(:, 1)) >= nLocatedPoints)
				dialog "All needed points were located" -set type=messagebox icon=infoicon buttons=ok title="NumeRe: Grid Locator";
				return window _nWinId -close;
			endif
			
			return void;
		endprocedure
		
		##~ Ergänze hier weitere lokale Prozeduren
		
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/gui/gridPainter.nlyt">
		#**********************************************************************************************
		* WINDOW-LAYOUT: gridPainter 
		* ============================================================================================
		* Hinzugefügt: 2021-05-03, um 09:46:26 *#
		
		##! \layout gridPainter
		##! Window containing a grapher displaying a map and a !!onclick!! event handler firing every 
		##! time the user clicks in the map.
		layout -title="NumeRe: Grid Painter" size={800,800}
			grapher -set id=0 size={750,750} onclick=$this~gridPainterEvent()
			group -type=horizontal
				dropdown "Square - Set value", "Square - Add value", "Gauss - Add value" -set id=3 value=1
				textfield "0.0" -set id=1 size={50,-1}
				statictext "Paint value" -set align="LC"
				spinbut -set label="Brush size" min=1 max=10 value=2 id=2
			endgroup
			prop sMapName = ""
		endlayout
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/gui/gridPainterEvent.nprc">
		#**********************************************************************************************
		* NUMERE-PROZEDUR: $gridPainterEvent()
		* ============================================================================================
		* Hinzugefügt: 2021-05-03, um 09:57:07 *#
		
		##! \procedure gridPainterEvent
		##! Map Painter window event handler, which is called, when the user clicks in the displayed
		##! grapher object. Will then extract the coordinates and painting parameters and add a "dot"
		##! of the selected size at the extracted coordinates.
		##!
		##! \param _nWinId  Current window ID
		##! \param _nItemId  The ID of the firing UI element
		##! \param _event{}  Key-value list containing additional event information
		procedure $gridPainterEvent(_nWinId, _nItemId, _event{}) :: event
			##~ Füge hier deine Kommandos und Ausdrücke ein.
			var nBrushSize, fBrushValue
			str sName, sVal, sOperation
			tab localMap(), gaussMat()
			cst coords{}, size{}
			
			## Get the window parameters
			nBrushSize = window _nWinId -get value item=2;
			nBrushSize -= 1;
			sVal = window _nWinId -get value item=1;
			fBrushValue = to_value(sVal);
			sName = window _nWinId -get value prop="sMapName";
			sOperation = window _nWinId -get value item=3;
			
			## Reference the global map
			localMap().aliasof(sName);
			
			## get coords
			sVal = getkeyval(_event{}, "value", "{0,0}", true);
			coords{} = to_value(sVal);
			
			## Convert to grid coords
			matop coords{} = rint(coordstogrid(localMap(:,1:2), transpose(coords{})));
			size{} = localMap().size;
			
			## Ensure that we're in the map
			if (or(coords{} < 1+nBrushSize) || or(coords{}+nBrushSize > size{}))
				return void;
			endif
			
			## Compensate for the two axis columns
			coords{2} += 2;
			
			## Apply the selected operation
			switch (sOperation)
			case "Square - Set value":
				matop localMap(coords{1}-nBrushSize:coords{1}+nBrushSize, coords{2}-nBrushSize:coords{2}+nBrushSize) = fBrushValue * one(1+2*nBrushSize);
				break;
			case "Square - Add value":
				matop localMap(coords{1}-nBrushSize:coords{1}+nBrushSize, coords{2}-nBrushSize:coords{2}+nBrushSize) += fBrushValue * one(1+2*nBrushSize);
				break;
			case "Gauss - Add value":
				datagrid exp(-norm(x,y)^2/2) -set [-2:2,-2:2] samples=1+2*nBrushSize target=gaussMat()
				matop localMap(coords{1}-nBrushSize:coords{1}+nBrushSize, coords{2}-nBrushSize:coords{2}+nBrushSize) += fBrushValue * gaussMat(:,3:);
				break;
			endswitch
			
			## Re-Plot the data grid
			dens localMap() -set aspect=1 streamto={_nWinId, 0} box
			
			return void;
		endprocedure
		
		
		#**Ende der Datei
		* NumeRe: Framework für Numerische Rechnungen | Freie numerische Software unter der GNU GPL v3
		* https://www.numere.org/
		**********************************************************************************************#
		
		
		
		
	<endfile>

	<file name="<procpath>/tools/gui/keyval.nlyt">
		#**********************************************************************************************
		* WINDOW-LAYOUT: keyval 
		* ============================================================================================
		* Hinzugefügt: 2021-05-02, um 13:59:10 *#
		
		##! \layout Key-Value List Browser
		##!
		##! Provides a graphical interface to visualize a key-value list in a human-readable
		##! fashion.
		layout -title="NumeRe: Key-Value List Browser" size={400,250}
			##~ Füge hier die Kommandos für Dein gewünschtes Layout ein.
			treelist -set label={"Key", "Value"} id=0
			button "Close" -set onclick=evt_close() align="C"
		endlayout
		
		#**Ende der Datei
